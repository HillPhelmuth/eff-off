# Required — server only. Never expose to the browser.
OPENAI_API_KEY=sk-...

# Optional overrides
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
# Default voice when the client does not pick one.
# One of: alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar
OPENAI_REALTIME_VOICE=ballad
CLIENT_SECRET_TTL_SECONDS=600
PORT=3000
NODE_ENV=development
